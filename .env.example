# Copy this file to .env.local and fill in any keys you need.
# .env.local is gitignored. Leave values blank to disable that feature.
#
# All of these can ALSO be set at runtime in the Settings UI (which stores
# them in ~/.wallettracker/config/settings.json). .env.local is just a
# convenient way to bake defaults into a deployment.

# ── Dome API (required for tracked-wallet trade logging) ──
# Sign up at https://domeapi.io to get a key.
# Without this, the app still runs — you just can't record tracked-wallet
# trades to CSV. Price feeds and orderbook streaming work without it.
DOME_API_KEY=

# ── Chainlink Data Streams (optional) ──
# Adds a Chainlink-oracle BTC price card to the Indicators page alongside
# Binance spot/futures. Skip these if you don't need it.
# Credentials come from https://chain.link/data-streams
CHAINLINK_API_KEY=
CHAINLINK_USER_SECRET=

# ── Polymarket endpoint overrides (optional) ──
# Leave blank to use Polymarket's public endpoints directly.
# Set these only if you're routing requests through your own proxy.
POLYMARKET_PROXY_CLOB=
POLYMARKET_PROXY_GAMMA=

# ── Port ──
# Port the dev/production server listens on. Defaults to 3030.
WALLET_TRACKER_PORT=3030
