# Public deploy build — set these in Vercel Project Settings → Environment Variables.
# All are OPTIONAL. The app runs end-to-end with NONE of them set:
# Polymarket and Binance feeds are public, and the wallet trade stream uses
# Polymarket's public Real-Time Data Socket.

# ── Chainlink Data Streams (optional) ──
# Adds a Chainlink-oracle BTC/ETH/SOL/XRP price card to the Indicators page.
# Without these, the Chainlink feed shows "Disabled".
# Get credentials at https://chain.link/data-streams
CHAINLINK_API_KEY=
CHAINLINK_USER_SECRET=

# ── Polymarket endpoint overrides (optional) ──
# Leave blank to use Polymarket's public endpoints directly.
# Set only if routing requests through your own proxy.
POLYMARKET_PROXY_CLOB=
POLYMARKET_PROXY_GAMMA=
